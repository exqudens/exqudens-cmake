{
    "version": "0.2.0",
    "inputs": [
        {
            "id": "ctest-selector",
            "type": "command",
            "command": "extension.commandvariable.pickStringRemember",
            "args": {
                "key": "ctest-selector",
                "addLabelToTop": "${remember:ctest-selector}",
                "description": "Select Test Entry",
                "options": [
                    "@_LAUNCH_TESTS@"
                ]
            }
        }
    ],
    "configurations": [
        {
            "name": "ctest",
            "type": "node",
            "request": "launch",
            "console": "internalConsole",
            "outputCapture": "std",
            "cwd": "${workspaceRoot}",
            "runtimeExecutable": "ctest",
            "runtimeArgs": [
                "--verbose",
                "--build-nocmake",
                "--test-dir", "${workspaceRoot}/build",
                "-R", "${input:ctest-selector}"
            ]
        }
    ]
}